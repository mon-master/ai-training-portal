---
import PublicLayout from '../layouts/PublicLayout.astro';

const url = Astro.url;
const error = url.searchParams.get('error');
const registered = url.searchParams.get('registered');

const errorMessages: Record<string, string> = {
  missing:           '必須項目が入力されていません',
  password_mismatch: 'パスワードが一致しません',
  duplicate:         'この社員番号はすでに登録されています',
  server:            'サーバーエラーが発生しました。しばらくしてから再度お試しください',
};

const features = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    color: '#3b82f6',
    title: '「検索」から「相談」へ',
    desc: 'ChatGPTに短い一言を打ち込んでいるだけの状態から、背景・目的を伝えて一緒に仕事を進める使い方へ変わります。',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" stroke="#8b5cf6" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    color: '#8b5cf6',
    title: '自分の業務専用GPTを作る',
    desc: '「毎回同じ説明をしなくていい」自分の仕事に特化したカスタムGPTを自分で設計・作成できるようになります。',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke="#06b6d4" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    color: '#06b6d4',
    title: 'AI活用を業務設計に組み込む',
    desc: '「AIに何を任せて、人間が何を判断するか」を整理し、業務フローの中にAIを位置づけられるようになります。',
  },
];

const targets = [
  { icon: '💭', text: 'ChatGPTに「〇〇について教えて」しか言えていない' },
  { icon: '😅', text: '使ってみたけどイマイチで、結局検索に戻った経験がある' },
  { icon: '⏰', text: '同じ作業を毎日繰り返していて、もっと楽にしたい' },
  { icon: '🤔', text: 'AIが気になっているけど、何から始めればいいか分からない' },
];

const phases = [
  { num: '前半', days: 'Day 1〜3', color: '#3b82f6', title: 'ChatGPT 基礎', desc: '検索から「仕事の相談」へ。背景つきのお願いで回答の質が劇的に変わります。' },
  { num: '中盤', days: 'Day 4〜6', color: '#8b5cf6', title: '自分に合わせる', desc: '設定・プロジェクト・プロンプト。自分の業務スタイルに合わせていきます。' },
  { num: '後半', days: 'Day 7〜10', color: '#06b6d4', title: '自分のGPTを作る', desc: '業務整理→GPT作成→フロー配置→改善提案。実践まで一気に走ります。' },
];
---

<PublicLayout title="AI研修プログラム" description="AIに仕事を奪われない人になる10日間研修。ChatGPTの基礎から自分の業務専用GPTを作るところまで。">

  <!-- ===== HERO ===== -->
  <section style="
    position:relative;min-height:100vh;
    display:flex;align-items:center;justify-content:center;
    overflow:hidden;
    background:linear-gradient(135deg,#050b18 0%,#0a1628 40%,#0d0b20 70%,#050b18 100%);
  " class="grid-bg">

    <!-- オーブ -->
    <div class="animate-orb" style="position:absolute;top:5%;left:5%;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(59,130,246,0.1) 0%,transparent 70%);pointer-events:none;"></div>
    <div class="animate-orb2" style="position:absolute;bottom:5%;right:3%;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(139,92,246,0.09) 0%,transparent 70%);pointer-events:none;"></div>

    <!-- フローティングドット -->
    {[
      {top:'12%',left:'18%',size:'6px',delay:'0s',color:'#3b82f6'},
      {top:'22%',right:'22%',size:'4px',delay:'1.2s',color:'#8b5cf6'},
      {top:'65%',left:'8%',size:'5px',delay:'2s',color:'#06b6d4'},
      {top:'72%',right:'18%',size:'4px',delay:'0.6s',color:'#3b82f6'},
      {top:'45%',left:'4%',size:'3px',delay:'1.8s',color:'#f59e0b'},
    ].map(({top,left,right,size,delay,color})=>(
      <div style={`position:absolute;top:${top};${left?`left:${left};`:`right:${right};`}width:${size};height:${size};border-radius:50%;background:${color};box-shadow:0 0 8px ${color};animation:dot-pulse 3s ease-in-out infinite ${delay};pointer-events:none;`}></div>
    ))}

    <div style="position:relative;z-index:10;text-align:center;padding:0 24px;max-width:820px;margin:0 auto;">

      <!-- バッジ -->
      <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 18px;border:1px solid rgba(59,130,246,0.4);border-radius:100px;background:rgba(59,130,246,0.08);font-size:0.78rem;color:#60a5fa;letter-spacing:0.08em;margin-bottom:32px;animation:fade-in 0.8s ease-out both;">
        <span style="width:7px;height:7px;border-radius:50%;background:#3b82f6;box-shadow:0 0 8px #3b82f6;animation:dot-pulse 2s ease-in-out infinite;"></span>
        社内AI研修プログラム — 10 Days
      </div>

      <!-- メインキャッチ -->
      <h1 style="font-size:clamp(2rem,5.5vw,3.8rem);font-weight:900;line-height:1.15;margin-bottom:20px;color:#f1f5f9;letter-spacing:-0.02em;animation:fade-up 0.9s ease-out 0.2s both;">
        AIに仕事を奪われない<br/>
        <span class="shimmer-text">人になる10日間</span>
      </h1>

      <p style="font-size:clamp(1rem,2.5vw,1.15rem);color:#94a3b8;margin-bottom:12px;line-height:1.7;animation:fade-up 0.9s ease-out 0.35s both;">
        ChatGPTをまだ「検索の道具」として使っていませんか？
      </p>
      <p style="font-size:0.92rem;color:#64748b;margin-bottom:48px;line-height:1.8;animation:fade-up 0.9s ease-out 0.45s both;">
        10日間で「仕事のパートナー」として使いこなし、<br/>
        自分の業務専用GPTを作れるようになります。
      </p>

      <!-- CTAボタン -->
      <div style="display:flex;flex-wrap:wrap;gap:14px;justify-content:center;animation:fade-up 0.9s ease-out 0.6s both;">
        <a href="#register" style="
          display:inline-flex;align-items:center;gap:8px;
          padding:15px 36px;border-radius:12px;
          font-size:1rem;font-weight:700;color:#fff;
          background:linear-gradient(135deg,#3b82f6,#8b5cf6);
          box-shadow:0 0 32px rgba(59,130,246,0.45);
          text-decoration:none;transition:all 0.25s;
        "
        onmouseover="this.style.boxShadow='0 0 56px rgba(59,130,246,0.7)';this.style.transform='translateY(-2px)'"
        onmouseout="this.style.boxShadow='0 0 32px rgba(59,130,246,0.45)';this.style.transform='translateY(0)'"
        >受講申し込み →</a>

        <a href="/login" style="
          display:inline-flex;align-items:center;gap:8px;
          padding:15px 36px;border-radius:12px;
          font-size:1rem;font-weight:600;color:#94a3b8;
          background:rgba(255,255,255,0.04);
          border:1px solid rgba(59,130,246,0.25);
          text-decoration:none;transition:all 0.25s;
        "
        onmouseover="this.style.color='#e2e8f0';this.style.background='rgba(59,130,246,0.08)';this.style.borderColor='rgba(59,130,246,0.5)'"
        onmouseout="this.style.color='#94a3b8';this.style.background='rgba(255,255,255,0.04)';this.style.borderColor='rgba(59,130,246,0.25)'"
        >すでに登録済みの方</a>
      </div>

      <!-- スクロール -->
      <div style="margin-top:64px;display:flex;flex-direction:column;align-items:center;gap:6px;animation:fade-in 1.2s 1.2s both;">
        <div style="font-size:0.68rem;color:#334155;letter-spacing:0.12em;">SCROLL</div>
        <div style="width:1px;height:40px;background:linear-gradient(to bottom,#3b82f6,transparent);animation:float 2s ease-in-out infinite;"></div>
      </div>
    </div>
  </section>

  <!-- ===== こんな方向け ===== -->
  <section style="padding:100px 24px;background:rgba(10,22,40,0.6);">
    <div style="max-width:900px;margin:0 auto;">
      <div class="reveal" style="text-align:center;margin-bottom:56px;">
        <div style="font-size:0.72rem;letter-spacing:0.15em;color:#3b82f6;font-weight:700;margin-bottom:10px;text-transform:uppercase;">For You</div>
        <h2 style="font-size:clamp(1.6rem,3.5vw,2.2rem);font-weight:900;color:#f1f5f9;">こんな方に向けた研修です</h2>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:14px;">
        {targets.map(({icon,text},i)=>(
          <div class={`reveal stagger-${i+1} glow-card`} style="border-radius:14px;padding:20px 24px;display:flex;align-items:center;gap:16px;">
            <span style="font-size:1.6rem;flex-shrink:0;">{icon}</span>
            <p style="font-size:0.88rem;color:#94a3b8;line-height:1.6;">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 身につくこと ===== -->
  <section style="padding:100px 24px;background:var(--c-bg);">
    <div style="max-width:1040px;margin:0 auto;">
      <div class="reveal" style="text-align:center;margin-bottom:56px;">
        <div style="font-size:0.72rem;letter-spacing:0.15em;color:#8b5cf6;font-weight:700;margin-bottom:10px;text-transform:uppercase;">What You'll Gain</div>
        <h2 style="font-size:clamp(1.6rem,3.5vw,2.2rem);font-weight:900;color:#f1f5f9;">10日間で身につくこと</h2>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;">
        {features.map(({icon,color,title,desc},i)=>(
          <div class={`reveal stagger-${i+1} glow-card`} style={`border-radius:18px;padding:32px 28px;border-top:3px solid ${color};`}>
            <div style={`width:48px;height:48px;border-radius:14px;background:${color}18;border:1px solid ${color}30;display:flex;align-items:center;justify-content:center;margin-bottom:20px;box-shadow:0 0 20px ${color}15;`} set:html={icon}></div>
            <h3 style={`font-size:1.05rem;font-weight:800;color:#f1f5f9;margin-bottom:10px;`}>{title}</h3>
            <p style="font-size:0.85rem;color:#94a3b8;line-height:1.8;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 研修の流れ ===== -->
  <section style="padding:100px 24px;background:rgba(10,22,40,0.5);">
    <div style="max-width:960px;margin:0 auto;">
      <div class="reveal" style="text-align:center;margin-bottom:56px;">
        <div style="font-size:0.72rem;letter-spacing:0.15em;color:#06b6d4;font-weight:700;margin-bottom:10px;text-transform:uppercase;">Program Flow</div>
        <h2 style="font-size:clamp(1.6rem,3.5vw,2.2rem);font-weight:900;color:#f1f5f9;">10日間の流れ</h2>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px;">
        {phases.map(({num,days,color,title,desc},i)=>(
          <div class={`reveal stagger-${i+1} glow-card`} style={`border-radius:18px;padding:28px;position:relative;overflow:hidden;`}>
            <div style={`position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,${color},transparent);`}></div>
            <div style={`font-size:0.65rem;font-weight:700;letter-spacing:0.12em;color:${color};margin-bottom:4px;text-transform:uppercase;`}>{num}</div>
            <div style={`font-size:0.75rem;color:${color}80;margin-bottom:16px;`}>{days}</div>
            <h3 style="font-size:1.1rem;font-weight:800;color:#f1f5f9;margin-bottom:10px;">{title}</h3>
            <p style="font-size:0.84rem;color:#94a3b8;line-height:1.75;">{desc}</p>
          </div>
        ))}
      </div>

      <!-- プログラム詳細 -->
      <div class="reveal glow-card" style="border-radius:18px;padding:32px;margin-top:28px;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:24px;">
        {[
          {label:'期間',value:'10日間'},
          {label:'形式',value:'オンライン自習'},
          {label:'1日の目安',value:'90〜120分'},
          {label:'必要ツール',value:'ChatGPT（Plus推奨）'},
          {label:'練習サポート',value:'専用AI活用トレーナー'},
          {label:'記録',value:'クリア報告システム'},
        ].map(({label,value})=>(
          <div>
            <div style="font-size:0.68rem;font-weight:700;letter-spacing:0.1em;color:#3b82f6;margin-bottom:4px;text-transform:uppercase;">{label}</div>
            <div style="font-size:0.95rem;font-weight:700;color:#e2e8f0;">{value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 受講申し込み ===== -->
  <section id="register" style="padding:100px 24px;background:var(--c-bg);">
    <div style="max-width:560px;margin:0 auto;">
      <div class="reveal" style="text-align:center;margin-bottom:48px;">
        <div style="font-size:0.72rem;letter-spacing:0.15em;color:#3b82f6;font-weight:700;margin-bottom:10px;text-transform:uppercase;">Sign Up</div>
        <h2 style="font-size:clamp(1.6rem,3.5vw,2rem);font-weight:900;color:#f1f5f9;margin-bottom:10px;">受講申し込み</h2>
        <p style="font-size:0.88rem;color:#94a3b8;">必要事項を入力して送信してください</p>
      </div>

      <!-- エラーメッセージ -->
      {error && (
        <div style="background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.3);border-radius:12px;padding:14px 20px;margin-bottom:24px;display:flex;align-items:center;gap:10px;">
          <span style="font-size:1rem;">⚠️</span>
          <p style="font-size:0.85rem;color:#fca5a5;">{errorMessages[error] ?? error}</p>
        </div>
      )}

      <!-- 登録完了メッセージ -->
      {registered && (
        <div style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);border-radius:12px;padding:14px 20px;margin-bottom:24px;display:flex;align-items:center;gap:10px;">
          <span style="font-size:1rem;">✅</span>
          <p style="font-size:0.85rem;color:#6ee7b7;">登録が完了しました。<a href="/login" style="color:#34d399;font-weight:700;">ログインページ</a>からログインしてください。</p>
        </div>
      )}

      <!-- フォーム -->
      <div class="reveal glow-card" style="border-radius:20px;padding:36px;border:1px solid rgba(59,130,246,0.2);">
        <form action="/api/register" method="POST" style="display:flex;flex-direction:column;gap:20px;">

          <!-- 氏名 -->
          <div>
            <label style="display:block;font-size:0.8rem;font-weight:700;color:#94a3b8;margin-bottom:8px;letter-spacing:0.05em;">
              氏名 <span style="color:#ef4444;">*</span>
            </label>
            <input type="text" name="name" required placeholder="山田 太郎" style="
              width:100%;padding:12px 16px;border-radius:10px;
              background:rgba(15,23,42,0.8);
              border:1px solid rgba(59,130,246,0.2);
              color:#e2e8f0;font-size:0.9rem;outline:none;
              transition:border-color 0.2s;box-sizing:border-box;
            "
            onfocus="this.style.borderColor='rgba(59,130,246,0.6)'"
            onblur="this.style.borderColor='rgba(59,130,246,0.2)'"
            />
          </div>

          <!-- 社員番号 -->
          <div>
            <label style="display:block;font-size:0.8rem;font-weight:700;color:#94a3b8;margin-bottom:8px;letter-spacing:0.05em;">
              社員番号 <span style="color:#ef4444;">*</span>
            </label>
            <input type="text" name="employeeId" required placeholder="EMP-0001" style="
              width:100%;padding:12px 16px;border-radius:10px;
              background:rgba(15,23,42,0.8);
              border:1px solid rgba(59,130,246,0.2);
              color:#e2e8f0;font-size:0.9rem;outline:none;
              transition:border-color 0.2s;box-sizing:border-box;
            "
            onfocus="this.style.borderColor='rgba(59,130,246,0.6)'"
            onblur="this.style.borderColor='rgba(59,130,246,0.2)'"
            />
          </div>

          <!-- 所属部署 -->
          <div>
            <label style="display:block;font-size:0.8rem;font-weight:700;color:#94a3b8;margin-bottom:8px;letter-spacing:0.05em;">
              所属部署 <span style="color:#ef4444;">*</span>
            </label>
            <input type="text" name="department" required placeholder="営業部" style="
              width:100%;padding:12px 16px;border-radius:10px;
              background:rgba(15,23,42,0.8);
              border:1px solid rgba(59,130,246,0.2);
              color:#e2e8f0;font-size:0.9rem;outline:none;
              transition:border-color 0.2s;box-sizing:border-box;
            "
            onfocus="this.style.borderColor='rgba(59,130,246,0.6)'"
            onblur="this.style.borderColor='rgba(59,130,246,0.2)'"
            />
          </div>

          <!-- メール -->
          <div>
            <label style="display:block;font-size:0.8rem;font-weight:700;color:#94a3b8;margin-bottom:8px;letter-spacing:0.05em;">
              メールアドレス <span style="color:#ef4444;">*</span>
            </label>
            <input type="email" name="email" required placeholder="yamada@example.com" style="
              width:100%;padding:12px 16px;border-radius:10px;
              background:rgba(15,23,42,0.8);
              border:1px solid rgba(59,130,246,0.2);
              color:#e2e8f0;font-size:0.9rem;outline:none;
              transition:border-color 0.2s;box-sizing:border-box;
            "
            onfocus="this.style.borderColor='rgba(59,130,246,0.6)'"
            onblur="this.style.borderColor='rgba(59,130,246,0.2)'"
            />
          </div>

          <!-- パスワード -->
          <div>
            <label style="display:block;font-size:0.8rem;font-weight:700;color:#94a3b8;margin-bottom:8px;letter-spacing:0.05em;">
              パスワード <span style="color:#ef4444;">*</span>
            </label>
            <input type="password" name="password" required placeholder="8文字以上" minlength="8" style="
              width:100%;padding:12px 16px;border-radius:10px;
              background:rgba(15,23,42,0.8);
              border:1px solid rgba(59,130,246,0.2);
              color:#e2e8f0;font-size:0.9rem;outline:none;
              transition:border-color 0.2s;box-sizing:border-box;
            "
            onfocus="this.style.borderColor='rgba(59,130,246,0.6)'"
            onblur="this.style.borderColor='rgba(59,130,246,0.2)'"
            />
          </div>

          <!-- パスワード確認 -->
          <div>
            <label style="display:block;font-size:0.8rem;font-weight:700;color:#94a3b8;margin-bottom:8px;letter-spacing:0.05em;">
              パスワード（確認） <span style="color:#ef4444;">*</span>
            </label>
            <input type="password" name="passwordConfirm" required placeholder="もう一度入力" minlength="8" style="
              width:100%;padding:12px 16px;border-radius:10px;
              background:rgba(15,23,42,0.8);
              border:1px solid rgba(59,130,246,0.2);
              color:#e2e8f0;font-size:0.9rem;outline:none;
              transition:border-color 0.2s;box-sizing:border-box;
            "
            onfocus="this.style.borderColor='rgba(59,130,246,0.6)'"
            onblur="this.style.borderColor='rgba(59,130,246,0.2)'"
            />
          </div>

          <!-- 送信ボタン -->
          <button type="submit" style="
            width:100%;padding:14px;border-radius:12px;
            background:linear-gradient(135deg,#3b82f6,#8b5cf6);
            color:#fff;font-size:1rem;font-weight:700;
            border:none;cursor:pointer;
            box-shadow:0 0 28px rgba(59,130,246,0.4);
            transition:all 0.25s;margin-top:4px;
          "
          onmouseover="this.style.boxShadow='0 0 48px rgba(59,130,246,0.65)';this.style.transform='translateY(-1px)'"
          onmouseout="this.style.boxShadow='0 0 28px rgba(59,130,246,0.4)';this.style.transform='translateY(0)'"
          >申し込む</button>

        </form>

        <!-- ログインリンク -->
        <p style="text-align:center;margin-top:24px;font-size:0.82rem;color:#64748b;">
          すでに登録済みの方は
