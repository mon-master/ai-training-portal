---
import Layout from '../layouts/Layout.astro';
import DayCard from '../components/DayCard.astro';
import { getCollection } from 'astro:content';

const days = (await getCollection('days')).sort((a, b) => a.data.day - b.data.day);
---

<Layout title="ホーム">
  <!-- ヒーローセクション -->
  <section class="bg-gradient-to-br from-blue-600 via-blue-700 to-blue-900 text-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-5xl mb-4">🤖</div>
      <h1 class="text-3xl md:text-4xl font-bold mb-4 leading-tight">
        AIに仕事を奪われない人になる<br class="hidden md:block" />
        <span class="text-yellow-300">10日間研修</span>
      </h1>
      <p class="text-blue-100 text-lg mb-2">
        〜検索するAIから、仕事を一緒に進めるAIへ〜
      </p>
      <p class="text-blue-200 text-sm max-w-xl mx-auto mt-4">
        ChatGPTをまだ「検索の道具」として使っている方へ。<br />
        10日間で「仕事のパートナー」として使いこなせるようになります。
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/curriculum"
           class="bg-white text-blue-700 font-bold px-6 py-3 rounded-xl hover:bg-blue-50 transition-colors shadow-lg">
          カリキュラムを見る
        </a>
        <a href="/gpts"
           class="bg-white/20 text-white font-bold px-6 py-3 rounded-xl hover:bg-white/30 transition-colors border border-white/30">
          GPTsの使い方
        </a>
      </div>
    </div>
  </section>

  <!-- 研修の3フェーズ -->
  <section class="py-12 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-center text-gray-800 mb-8">研修の流れ</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-green-50 border border-green-200 rounded-xl p-6">
          <div class="text-3xl mb-3">📖</div>
          <div class="text-xs font-bold text-green-600 uppercase tracking-wider mb-1">前半 Day 1〜3</div>
          <h3 class="font-bold text-gray-800 mb-2">ChatGPT基礎</h3>
          <p class="text-sm text-gray-600">検索から「仕事の相談」へ。背景つきのお願いで、回答の質が劇的に変わります。</p>
        </div>
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6">
          <div class="text-3xl mb-3">⚙️</div>
          <div class="text-xs font-bold text-yellow-600 uppercase tracking-wider mb-1">中盤 Day 4〜6</div>
          <h3 class="font-bold text-gray-800 mb-2">自分に合わせる</h3>
          <p class="text-sm text-gray-600">設定・プロジェクト・指示の作り方を学び、ChatGPTを自分仕様にカスタマイズします。</p>
        </div>
        <div class="bg-purple-50 border border-purple-200 rounded-xl p-6">
          <div class="text-3xl mb-3">🚀</div>
          <div class="text-xs font-bold text-purple-600 uppercase tracking-wider mb-1">後半 Day 7〜10</div>
          <h3 class="font-bold text-gray-800 mb-2">自分のGPTを作る</h3>
          <p class="text-sm text-gray-600">業務専用GPTを作成し、業務フローに組み込んで、改善提案にまとめます。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ChatGPT活用レベル -->
  <section class="bg-white py-12 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-center text-gray-800 mb-8">ChatGPT活用レベル（10段階）</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        {[
          { level: 1, label: '検索・確認', color: 'bg-blue-50 border-blue-200 text-blue-700' },
          { level: 2, label: '言い換え', color: 'bg-blue-50 border-blue-200 text-blue-700' },
          { level: 3, label: '整理', color: 'bg-green-50 border-green-200 text-green-700' },
          { level: 4, label: '抜け漏れ確認', color: 'bg-green-50 border-green-200 text-green-700' },
          { level: 5, label: '壁打ち・相談', color: 'bg-yellow-50 border-yellow-200 text-yellow-700' },
          { level: 6, label: 'テンプレート化', color: 'bg-yellow-50 border-yellow-200 text-yellow-700' },
          { level: 7, label: '業務の見える化', color: 'bg-orange-50 border-orange-200 text-orange-700' },
          { level: 8, label: '改善案づくり', color: 'bg-orange-50 border-orange-200 text-orange-700' },
          { level: 9, label: 'AI・人・システムの役割分担', color: 'bg-purple-50 border-purple-200 text-purple-700' },
          { level: 10, label: 'AIオーケストレーション', color: 'bg-purple-50 border-purple-200 text-purple-700' },
        ].map(({ level, label, color }) => (
          <div class={`border rounded-lg p-3 text-center ${color}`}>
            <div class="font-bold text-lg">Lv.{level}</div>
            <div class="text-xs mt-1 leading-tight">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 10日間カリキュラム一覧 -->
  <section class="py-12 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-gray-800">10日間カリキュラム</h2>
        <a href="/curriculum" class="text-blue-600 text-sm hover:underline">詳細を見る →</a>
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        {days.map((day) => (
          <DayCard
            day={day.data.day}
            title={day.data.title}
            level={day.data.level}
            duration={day.data.duration}
            id={day.id}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 重要ルール -->
  <section class="bg-amber-50 border-y border-amber-200 py-10 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-lg font-bold text-amber-800 mb-5 flex items-center gap-2">
        <span>⚠️</span> 研修中の重要ルール
      </h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-bold text-green-700 mb-2">✅ AIに任せてよいこと</h3>
          <ul class="text-sm text-gray-700 space-y-1">
            <li>• 文章の下書き・言い換え・整理</li>
            <li>• チェックリスト作成</li>
            <li>• 抜け漏れ確認</li>
            <li>• 改善案のたたき台</li>
            <li>• メール返信案・Chatwork投稿文</li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-red-700 mb-2">❌ AIに任せてはいけないこと</h3>
          <ul class="text-sm text-gray-700 space-y-1">
            <li>• お客様への最終回答</li>
            <li>• 請求金額・在庫数の確定</li>
            <li>• 返金・クレーム対応の最終判断</li>
            <li>• 個人情報・機密情報の入力</li>
            <li>• 上司確認が必要な判断</li>
          </ul>
        </div>
      </div>
      <p class="text-sm font-bold text-amber-800 mt-5 text-center">
        最終判断は、必ず人間が行います。
      </p>
    </div>
  </section>

  <!-- ワークログ提出 -->
  <section class="py-12 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <div class="text-4xl mb-4">📝</div>
      <h2 class="text-xl font-bold text-gray-800 mb-3">ワークログを提出する</h2>
      <p class="text-gray-600 text-sm mb-6">
        各Dayのワーク後に、学びの記録を提出してください。<br />
        GPTsで「終了」と入力してまとめを取得し、フォームに貼り付けて送信します。
      </p>
      <a href="/submit"
         class="inline-block bg-blue-600 text-white font-bold px-8 py-4 rounded-xl hover:bg-blue-700 transition-colors shadow-lg">
        ワークログ提出フォームへ
      </a>
    </div>
  </section>
</Layout>
