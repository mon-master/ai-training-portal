---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const days = await getCollection('days');
  return days.map((day) => ({
    params: { slug: day.id.replace('.md', '') },
    props: { day },
  }));
}

const { day } = Astro.props;
const { Content } = await render(day);

const allDays = (await getCollection('days')).sort((a, b) => a.data.day - b.data.day);
const currentIndex = allDays.findIndex(d => d.id === day.id);
const prevDay = currentIndex > 0 ? allDays[currentIndex - 1] : null;
const nextDay = currentIndex < allDays.length - 1 ? allDays[currentIndex + 1] : null;

function getPhase(dayNum: number): { label: string; color: string; border: string } {
  if (dayNum <= 3) return { label: '前半：ChatGPT基礎', color: '#3b82f6', border: 'rgba(59,130,246,0.3)' };
  if (dayNum <= 6) return { label: '中盤：自分に合わせる', color: '#8b5cf6', border: 'rgba(139,92,246,0.3)' };
  return { label: '後半：自分のGPTを作る', color: '#06b6d4', border: 'rgba(6,182,212,0.3)' };
}

const phase = getPhase(day.data.day);
const dayNum = String(day.data.day).padStart(2, '0');
---

<Layout title={`Day${day.data.day}: ${day.data.title}`} description={day.data.goals.join('。')}>

  <!-- ===== ヘッダー ===== -->
  <div style="
    background:linear-gradient(135deg,#050b18 0%,#0a1628 100%);
    border-bottom:1px solid rgba(59,130,246,0.15);
    padding:48px 24px 40px;
    position:relative;overflow:hidden;
  " class="grid-bg">
    <div style="position:absolute;top:-80px;right:-80px;width:350px;height:350px;border-radius:50%;background:radial-gradient(circle,rgba(59,130,246,0.08),transparent 70%);pointer-events:none;"></div>

    <div style="max-width:860px;margin:0 auto;position:relative;z-index:1;">
      <!-- パンくず -->
      <div style="font-size:0.75rem;margin-bottom:20px;">
        <a href="/" style="color:#475569;text-decoration:none;" onmouseover="this.style.color='#60a5fa'" onmouseout="this.style.color='#475569'">ホーム</a>
        <span style="margin:0 8px;color:#1e293b;">›</span>
        <a href="/curriculum" style="color:#475569;text-decoration:none;" onmouseover="this.style.color='#60a5fa'" onmouseout="this.style.color='#475569'">カリキュラム</a>
        <span style="margin:0 8px;color:#1e293b;">›</span>
        <span style="color:#60a5fa;">Day{day.data.day}</span>
      </div>

      <div style="display:flex;align-items:flex-start;gap:20px;flex-wrap:wrap;">
        <!-- Day番号バッジ -->
        <div style={`
          flex-shrink:0;width:72px;height:72px;border-radius:18px;
          background:linear-gradient(135deg,${phase.color}25,${phase.color}08);
          border:2px solid ${phase.color}50;
          display:flex;flex-direction:column;align-items:center;justify-content:center;
          box-shadow:0 0 30px ${phase.color}20;
        `}>
          <div style={`font-size:0.6rem;font-weight:700;color:${phase.color};letter-spacing:0.1em;`}>DAY</div>
          <div style={`font-size:1.8rem;font-weight:900;color:${phase.color};line-height:1;`}>{dayNum}</div>
        </div>

        <div style="flex:1;min-width:200px;">
          <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;">
            <span style={`font-size:0.72rem;font-weight:700;color:${phase.color};background:${phase.color}15;border:1px solid ${phase.border};padding:3px 10px;border-radius:100px;`}>
              {phase.label}
            </span>
            <span style="font-size:0.72rem;color:#475569;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);padding:3px 10px;border-radius:100px;">
              ⏱ {day.data.duration}
            </span>
            <span style="font-size:0.72rem;color:#475569;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);padding:3px 10px;border-radius:100px;">
              {day.data.level}
            </span>
          </div>
          <h1 style="font-size:clamp(1.3rem,3.5vw,2rem);font-weight:900;color:#f1f5f9;line-height:1.3;">
            {day.data.title}
          </h1>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:860px;margin:0 auto;padding:48px 24px;">

    <!-- ===== このDayの進め方（最優先表示） ===== -->
    <section style="margin-bottom:48px;" class="reveal">
      <div style="
        border-radius:20px;
        border:1px solid rgba(59,130,246,0.2);
        background:rgba(13,27,46,0.6);
        overflow:hidden;
      ">
        <!-- ヘッダー -->
        <div style="
          padding:18px 24px;
          background:linear-gradient(90deg,rgba(59,130,246,0.12),rgba(139,92,246,0.08));
          border-bottom:1px solid rgba(59,130,246,0.15);
          display:flex;align-items:center;gap:10px;
        ">
          <div style="width:32px;height:32px;border-radius:8px;background:rgba(59,130,246,0.2);border:1px solid rgba(59,130,246,0.3);display:flex;align-items:center;justify-content:center;font-size:0.9rem;">🗺️</div>
          <h2 style="font-size:1rem;font-weight:700;color:#e2e8f0;margin:0;">このDayの進め方</h2>
        </div>

        <!-- ステップ -->
        <div style="padding:20px 24px;">
          <div style="display:flex;flex-direction:column;gap:0;">
            {[
              { icon:'📖', label:'このページを読む', desc:'「学ぶこと」と「練習ワーク」を確認する', color:'#3b82f6' },
              { icon:'🤖', label:'AI活用トレーナーを開く', desc:'GPTs活用ページから専用GPTを開く', color:'#8b5cf6', link:'/gpts' },
              { icon:'▶️', label:'「開始」と入力', desc:'GPTsに「開始」と打つだけでワークが始まる', color:'#06b6d4' },
              { icon:'💬', label:'業務の相談・練習をする', desc:'個人情報・機密情報は入力しないこと', color:'#10b981', warn:true },
              { icon:'⏹️', label:'「終了」と入力', desc:'まとめが自動生成される', color:'#f59e0b' },
              { icon:'📝', label:'クリア報告を送る', desc:'まとめを確認して提出フォームへ', color:'#ec4899', link:'/submit' },
            ].map(({ icon, label, desc, color, link, warn }, i) => (
              <div style={`
                display:flex;align-items:center;gap:14px;
                padding:14px 0;
                ${i < 5 ? `border-bottom:1px solid rgba(59,130,246,0.08);` : ''}
              `}>
                <!-- 番号 -->
                <div style={`
                  flex-shrink:0;
                  width:36px;height:36px;border-radius:10px;
                  background:${color}15;border:1px solid ${color}40;
                  display:flex;align-items:center;justify-content:center;
                  font-size:1rem;
                `}>{icon}</div>

                <!-- テキスト -->
                <div style="flex:1;min-width:0;">
                  <div style={`font-size:0.88rem;font-weight:700;color:#e2e8f0;margin-bottom:2px;`}>
                    <span style={`font-size:0.68rem;font-weight:700;color:${color};margin-right:8px;font-variant-numeric:tabular-nums;`}>STEP {String(i+1).padStart(2,'0')}</span>
                    {label}
                    {warn && <span style="font-size:0.65rem;color:#f59e0b;margin-left:8px;background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2);padding:1px 6px;border-radius:4px;">要注意</span>}
                  </div>
                  <div style="font-size:0.78rem;color:#475569;">{desc}</div>
                </div>

                <!-- リンクがあれば -->
                {link && (
                  <a href={link} style={`
                    flex-shrink:0;
                    font-size:0.75rem;font-weight:600;
                    color:${color};text-decoration:none;
                    padding:5px 12px;border:1px solid ${color}40;border-radius:8px;
                    background:${color}08;
                    transition:all 0.2s;
                    white-space:nowrap;
                  `}
                  onmouseover={`this.style.background='${color}20';`}
                  onmouseout={`this.style.background='${color}08';`}
                  >開く →</a>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 今日のゴール ===== -->
    <section style="margin-bottom:36px;" class="reveal">
      <div style="
        border-radius:16px;
        border:1px solid rgba(59,130,246,0.2);
        background:rgba(59,130,246,0.05);
        padding:24px 28px;
      ">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
          <div style="width:32px;height:32px;border-radius:8px;background:rgba(59,130,246,0.2);border:1px solid rgba(59,130,246,0.3);display:flex;align-items:center;justify-content:center;font-size:0.9rem;">🎯</div>
          <h2 style="font-size:1rem;font-weight:700;color:#60a5fa;margin:0;">今日のゴール</h2>
        </div>
        <ul style="display:flex;flex-direction:column;gap:10px;list-style:none;padding:0;margin:0;">
          {day.data.goals.map((goal: string) => (
            <li style="display:flex;align-items:flex-start;gap:10px;">
              <div style="flex-shrink:0;width:22px;height:22px;border-radius:50%;background:rgba(59,130,246,0.2);border:1px solid rgba(59,130,246,0.4);display:flex;align-items:center;justify-content:center;font-size:0.7rem;color:#60a5fa;margin-top:1px;">✓</div>
              <span style="font-size:0.9rem;color:#cbd5e1;line-height:1.6;">{goal}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ===== 本文コンテンツ ===== -->
    <section style="margin-bottom:36px;" class="reveal">
      <div style="
        border-radius:16px;
        border:1px solid rgba(59,130,246,0.1);
        background:rgba(13,27,46,0.5);
        padding:32px 36px;
      " class="prose prose-invert prose-sm max-w-none
        prose-headings:font-bold prose-headings:text-slate-200
        prose-h2:text-lg prose-h2:border-b prose-h2:border-slate-700 prose-h2:pb-2 prose-h2:mb-4
        prose-h3:text-base prose-h3:text-blue-400
        prose-p:text-slate-400 prose-p:leading-relaxed
        prose-li:text-slate-400
        prose-code:bg-slate-800 prose-code:text-blue-300 prose-code:px-1.5 prose-code:rounded prose-code:text-xs
        prose-pre:bg-slate-900 prose-pre:border prose-pre:border-slate-700
        prose-strong:text-slate-200
        prose-table:text-sm
        prose-blockquote:border-blue-500 prose-blockquote:text-slate-400">
        <Content />
      </div>
    </section>

    <!-- ===== 今日の提出物 ===== -->
    <section style="margin-bottom:36px;" class="reveal">
      <div style="
        border-radius:16px;
        border:1px solid rgba(245,158,11,0.2);
        background:rgba(245,158,11,0.05);
        padding:24px 28px;
      ">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
          <div style="width:32px;height:32px;border-radius:8px;background:rgba(245,158,11,0.15);border:1px solid rgba(245,158,11,0.3);display:flex;align-items:center;justify-content:center;font-size:0.9rem;">📋</div>
          <h2 style="font-size:1rem;font-weight:700;color:#f59e0b;margin:0;">今日の提出物</h2>
        </div>
        <p style="font-size:0.9rem;color:#94a3b8;line-height:1.7;">{day.data.deliverable}</p>
      </div>
    </section>

    <!-- ===== クリア報告CTA ===== -->
    <section style="margin-bottom:48px;" class="reveal">
      <div style="
        border-radius:20px;
        border:1px solid rgba(59,130,246,0.2);
        background:linear-gradient(135deg,rgba(59,130,246,0.08),rgba(139,92,246,0.05));
        padding:36px 32px;
        text-align:center;
        position:relative;overflow:hidden;
      ">
        <div style="position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(59,130,246,0.1),transparent 70%);pointer-events:none;"></div>
        <div style="position:relative;z-index:1;">
          <div style="font-size:2rem;margin-bottom:12px;">📝</div>
          <h3 style="font-size:1.1rem;font-weight:800;color:#f1f5f9;margin-bottom:8px;">ワークが終わったら提出しましょう</h3>
          <p style="font-size:0.85rem;color:#64748b;line-height:1.7;margin-bottom:24px;">
            GPTsで「<strong style="color:#60a5fa;">終了</strong>」と入力してまとめを作成し、<br />
            個人情報が含まれていないか確認してから提出フォームに貼り付けてください。
          </p>
          <a href="/submit" style="
            display:inline-flex;align-items:center;gap:8px;
            padding:13px 32px;border-radius:12px;
            font-size:0.95rem;font-weight:700;color:#fff;
            background:linear-gradient(135deg,#3b82f6,#8b5cf6);
            text-decoration:none;
            box-shadow:0 0 25px rgba(59,130,246,0.35);
            transition:all 0.3s ease;
          "
          onmouseover="this.style.boxShadow='0 0 40px rgba(59,130,246,0.6)';this.style.transform='translateY(-2px)'"
          onmouseout="this.style.boxShadow='0 0 25px rgba(59,130,246,0.35)';this.style.transform='translateY(0)'"
          >クリア報告を送る →</a>
        </div>
      </div>
    </section>

    <!-- ===== 前後ナビ ===== -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;" class="reveal">
      {prevDay ? (
        <a href={`/days/${prevDay.id.replace('.md', '')}`}
           class="glow-card"
           style="border-radius:14px;padding:18px 20px;text-decoration:none;display:block;"
        >
          <div style="font-size:0.7rem;color:#475569;margin-bottom:4px;">← 前の日</div>
          <div style="font-size:0.72rem;font-weight:700;color:#3b82f6;margin-bottom:4px;">Day{prevDay.data.day}</div>
          <div style="font-size:0.85rem;font-weight:600;color:#cbd5e1;line-height:1.4;">{prevDay.data.title}</div>
        </a>
      ) : <div></div>}

      {nextDay ? (
        <a href={`/days/${nextDay.id.replace('.md', '')}`}
           class="glow-card"
           style="border-radius:14px;padding:18px 20px;text-decoration:none;display:block;text-align:right;"
        >
          <div style="font-size:0.7rem;color:#475569;margin-bottom:4px;">次の日 →</div>
          <div style="font-size:0.72rem;font-weight:700;color:#3b82f6;margin-bottom:4px;">Day{nextDay.data.day}</div>
          <div style="font-size:0.85rem;font-weight:600;color:#cbd5e1;line-height:1.4;">{nextDay.data.title}</div>
        </a>
      ) : <div></div>}
    </div>

  </div>
</Layout>
