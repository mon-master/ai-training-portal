---
import Layout from '../layouts/Layout.astro';
import DayCard from '../components/DayCard.astro';
import { getCollection } from 'astro:content';

const days = (await getCollection('days')).sort((a, b) => a.data.day - b.data.day);

const phases = [
  { label: '前半', days: 'Day 1〜3', theme: 'ChatGPT 基礎', desc: '検索から「仕事の相談」へ', color: '#3b82f6', glow: 'rgba(59,130,246,0.15)', days_data: days.filter(d => d.data.day <= 3) },
  { label: '中盤', days: 'Day 4〜6', theme: '自分に合わせる', desc: '設定・プロジェクト・指示の作り方', color: '#8b5cf6', glow: 'rgba(139,92,246,0.15)', days_data: days.filter(d => d.data.day >= 4 && d.data.day <= 6) },
  { label: '後半', days: 'Day 7〜10', theme: '自分のGPTを作る', desc: '業務GPT作成・フロー配置・改善提案', color: '#06b6d4', glow: 'rgba(6,182,212,0.15)', days_data: days.filter(d => d.data.day >= 7) },
];

const howToSteps = [
  {
    num: '01', icon: '📖',
    title: 'このページでコンテンツを読む',
    desc: '各DayのページでそのDayの「学ぶこと」と「練習ワーク」を確認します。',
    color: '#3b82f6',
  },
  {
    num: '02', icon: '🤖',
    title: 'AI活用トレーナーを開く',
    desc: '「GPTs活用」ページからカスタムGPT「AI活用トレーナー」を開きます。',
    color: '#8b5cf6',
    link: '/gpts',
  },
  {
    num: '03', icon: '▶️',
    title: '「開始」と入力してワーク開始',
    desc: 'GPTsに「開始」と入力するだけで、そのDayのワークが自動的に始まります。',
    color: '#06b6d4',
  },
  {
    num: '04', icon: '💬',
    title: '業務の相談・練習をする',
    desc: '実際の業務をテーマに、ChatGPTと一緒に仕事を進めてみます。個人情報・機密情報は入力しないこと。',
    color: '#10b981',
  },
  {
    num: '05', icon: '⏹️',
    title: '「終了」と入力してまとめを取得',
    desc: 'GPTsに「終了」と入力すると、やり取りのまとめが自動生成されます。',
    color: '#f59e0b',
  },
  {
    num: '06', icon: '📝',
    title: 'ワークログを提出する',
    desc: 'まとめを確認して個人情報が含まれていないか確認し、提出フォームに貼り付けて送信します。',
    color: '#ec4899',
    link: '/submit',
  },
];
---

<Layout title="カリキュラム" description="AIに仕事を奪われない人になる10日間研修のカリキュラム">

  <!-- ===== ヘッダー ===== -->
  <div style="
    background: linear-gradient(135deg, #050b18 0%, #0a1628 100%);
    border-bottom: 1px solid rgba(59,130,246,0.15);
    padding: 48px 24px 40px;
    position: relative; overflow: hidden;
  " class="grid-bg">
    <div style="position:absolute;top:-100px;right:-100px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(59,130,246,0.07),transparent 70%);pointer-events:none;"></div>
    <div style="max-width: 1080px; margin: 0 auto; position: relative; z-index: 1;">
      <div style="font-size:0.75rem;color:#3b82f6;margin-bottom:10px;">
        <a href="/" style="color:#475569;text-decoration:none;" onmouseover="this.style.color='#60a5fa'" onmouseout="this.style.color='#475569'">ホーム</a>
        <span style="margin:0 8px;color:#1e293b;">›</span>
        <span style="color:#60a5fa;">カリキュラム</span>
      </div>
      <h1 style="font-size:clamp(1.8rem,4vw,2.6rem);font-weight:900;color:#f1f5f9;margin-bottom:10px;">10日間カリキュラム</h1>
      <p style="color:#475569;font-size:0.95rem;">ChatGPT活用レベル1〜10を段階的に学ぶプログラム</p>
    </div>
  </div>

  <div style="max-width: 1080px; margin: 0 auto; padding: 64px 24px;">

    <!-- ===== 研修の実施手順（最優先） ===== -->
    <section style="margin-bottom: 80px;">
      <div class="reveal" style="text-align:center;margin-bottom:48px;">
        <div style="font-size:0.75rem;letter-spacing:0.15em;color:#3b82f6;font-weight:700;margin-bottom:10px;text-transform:uppercase;">How to Do</div>
        <h2 style="font-size:clamp(1.5rem,3vw,2rem);font-weight:800;color:#f1f5f9;margin-bottom:10px;">1日の実施手順</h2>
        <p style="color:#475569;font-size:0.9rem;max-width:520px;margin:0 auto;">各Dayはこの6ステップで進めます。毎日同じ流れなので、慣れると自然にできるようになります。</p>
      </div>

      <!-- ステップ一覧 -->
      <div style="position:relative;">
        <!-- 縦線（デスクトップ） -->
        <div class="hidden md:block" style="
          position:absolute; left:50%; top:0; bottom:0;
          width:1px; background:linear-gradient(to bottom,transparent,rgba(59,130,246,0.3),rgba(139,92,246,0.3),transparent);
          transform:translateX(-50%); pointer-events:none;
        "></div>

        <div style="display:flex;flex-direction:column;gap:20px;">
          {howToSteps.map(({ num, icon, title, desc, color, link }, i) => (
            <div class={`reveal stagger-${i + 1}`} style={`
              display: grid;
              grid-template-columns: 1fr 64px 1fr;
              align-items: center;
              gap: 24px;
            `}>
              <!-- 左コンテンツ（偶数は空） -->
              <div style={i % 2 === 0 ? '' : 'visibility:hidden;'} class="max-md:hidden">
                {i % 2 === 0 && (
                  <div class="glow-card" style={`
                    border-radius:16px;padding:24px;
                    border-left:3px solid ${color};
                    margin-left:auto;max-width:380px;
                  `}>
                    <div style={`font-size:0.7rem;font-weight:700;letter-spacing:0.1em;color:${color};margin-bottom:6px;`}>STEP {num}</div>
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                      <span style="font-size:1.2rem;">{icon}</span>
                      <h3 style="font-size:0.95rem;font-weight:700;color:#e2e8f0;">{title}</h3>
                    </div>
                    <p style="font-size:0.83rem;color:#64748b;line-height:1.7;">{desc}</p>
                    {link && (
                      <a href={link} style={`
                        display:inline-flex;align-items:center;gap:6px;
                        margin-top:12px;font-size:0.78rem;font-weight:600;
                        color:${color};text-decoration:none;
                        padding:5px 12px;border:1px solid ${color}40;border-radius:8px;
                        background:${color}10;
                        transition:all 0.2s;
                      `}
                      onmouseover={`this.style.background='${color}20';`}
                      onmouseout={`this.style.background='${color}10';`}
                      >開く →</a>
                    )}
                  </div>
                )}
              </div>

              <!-- 中央のアイコン -->
              <div style="display:flex;flex-direction:column;align-items:center;gap:4px;">
                <div style={`
                  width:56px;height:56px;border-radius:50%;
                  background:linear-gradient(135deg,${color}20,${color}08);
                  border:2px solid ${color}50;
                  display:flex;align-items:center;justify-content:center;
                  font-size:1.3rem;
                  box-shadow:0 0 20px ${color}20;
                  position:relative;z-index:1;
                `}>{icon}</div>
                <div style={`font-size:0.68rem;font-weight:700;color:${color};letter-spacing:0.05em;`}>{num}</div>
              </div>

              <!-- 右コンテンツ（奇数は空） -->
              <div style={i % 2 === 1 ? '' : 'visibility:hidden;'} class="max-md:hidden">
                {i % 2 === 1 && (
                  <div class="glow-card" style={`
                    border-radius:16px;padding:24px;
                    border-left:3px solid ${color};
                    max-width:380px;
                  `}>
                    <div style={`font-size:0.7rem;font-weight:700;letter-spacing:0.1em;color:${color};margin-bottom:6px;`}>STEP {num}</div>
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                      <span style="font-size:1.2rem;">{icon}</span>
                      <h3 style="font-size:0.95rem;font-weight:700;color:#e2e8f0;">{title}</h3>
                    </div>
                    <p style="font-size:0.83rem;color:#64748b;line-height:1.7;">{desc}</p>
                    {link && (
                      <a href={link} style={`
                        display:inline-flex;align-items:center;gap:6px;
                        margin-top:12px;font-size:0.78rem;font-weight:600;
                        color:${color};text-decoration:none;
                        padding:5px 12px;border:1px solid ${color}40;border-radius:8px;
                        background:${color}10;
                        transition:all 0.2s;
                      `}
                      onmouseover={`this.style.background='${color}20';`}
                      onmouseout={`this.style.background='${color}10';`}
                      >開く →</a>
                    )}
                  </div>
                )}
              </div>

              <!-- モバイル用（フル幅） -->
              <div class="md:hidden col-span-3" style="padding:0 8px;">
                <div class="glow-card" style={`border-radius:16px;padding:20px;border-left:3px solid ${color};`}>
                  <div style={`font-size:0.7rem;font-weight:700;letter-spacing:0.1em;color:${color};margin-bottom:6px;`}>STEP {num}</div>
                  <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                    <span style="font-size:1.2rem;">{icon}</span>
                    <h3 style="font-size:0.9rem;font-weight:700;color:#e2e8f0;">{title}</h3>
                  </div>
                  <p style="font-size:0.83rem;color:#64748b;line-height:1.7;">{desc}</p>
                  {link && (
                    <a href={link} style={`
                      display:inline-flex;align-items:center;gap:6px;
                      margin-top:10px;font-size:0.78rem;font-weight:600;
                      color:${color};text-decoration:none;
                      padding:5px 12px;border:1px solid ${color}40;border-radius:8px;
                      background:${color}10;
                    `}>開く →</a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- ポイント -->
      <div class="reveal" style="
        margin-top:48px;
        padding:24px 28px;
        border-radius:16px;
        background:rgba(245,158,11,0.06);
        border:1px solid rgba(245,158,11,0.2);
        display:flex;align-items:flex-start;gap:14px;
      ">
        <span style="font-size:1.4rem;flex-shrink:0;">⚠️</span>
        <div>
          <div style="font-weight:700;color:#f59e0b;font-size:0.9rem;margin-bottom:6px;">個人情報・機密情報は入力しないこと</div>
          <p style="font-size:0.85rem;color:#64748b;line-height:1.7;">
            ChatGPTにはお客様の名前・注文番号・住所・メールアドレスなどの個人情報や、会社の機密情報は絶対に入力しないでください。
            ワークログ提出前にも必ず確認してください。
          </p>
        </div>
      </div>
    </section>

    <!-- ===== 1日のタイムライン ===== -->
    <section style="margin-bottom:80px;">
      <div class="reveal" style="text-align:center;margin-bottom:40px;">
        <div style="font-size:0.75rem;letter-spacing:0.15em;color:#06b6d4;font-weight:700;margin-bottom:10px;text-transform:uppercase;">Daily Schedule</div>
        <h2 style="font-size:clamp(1.4rem,3vw,1.8rem);font-weight:800;color:#f1f5f9;">1日の時間配分（目安）</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;" class="reveal">
        {[
          { time: '0:00〜0:10', label: '振り返り・今日の確認', icon: '🔄', color: '#3b82f6' },
          { time: '0:10〜0:40', label: '学ぶこと（レクチャー）', icon: '📖', color: '#8b5cf6' },
          { time: '0:40〜1:10', label: '練習ワーク（GPTs）', icon: '💬', color: '#06b6d4' },
          { time: '1:10〜1:20', label: '振り返り・提出物確認', icon: '✅', color: '#10b981' },
          { time: '1:20〜1:30', label: 'ワークログ提出', icon: '📝', color: '#f59e0b' },
        ].map(({ time, label, icon, color }, i) => (
          <div class={`glow-card reveal stagger-${i + 1}`} style={`border-radius:14px;padding:18px 16px;text-align:center;border-top:2px solid ${color}50;`}>
            <div style={`font-size:1.4rem;margin-bottom:8px;`}>{icon}</div>
            <div style={`font-size:0.68rem;font-weight:700;color:${color};margin-bottom:6px;font-variant-numeric:tabular-nums;`}>{time}</div>
            <div style="font-size:0.82rem;color:#94a3b8;line-height:1.4;">{label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== フェーズ別カリキュラム ===== -->
    <section>
      <div class="reveal" style="text-align:center;margin-bottom:48px;">
        <div style="font-size:0.75rem;letter-spacing:0.15em;color:#8b5cf6;font-weight:700;margin-bottom:10px;text-transform:uppercase;">Curriculum</div>
        <h2 style="font-size:clamp(1.4rem,3vw,1.8rem);font-weight:800;color:#f1f5f9;">フェーズ別カリキュラム</h2>
      </div>

      {phases.map((phase, pi) => (
        <div style="margin-bottom:56px;">
          <div class={`reveal stagger-${pi + 1}`} style={`
            display:flex;align-items:center;gap:14px;
            margin-bottom:24px;
            padding:16px 20px;
            border-radius:14px;
            background:${phase.glow};
            border:1px solid ${phase.color}30;
          `}>
            <div style={`
              width:48px;height:48px;border-radius:12px;
              background:${phase.color}20;border:1px solid ${phase.color}40;
              display:flex;align-items:center;justify-content:center;
              font-weight:900;font-size:1.1rem;color:${phase.color};
              flex-shrink:0;
            `}>{pi + 1}</div>
            <div>
              <div style={`font-size:0.72rem;font-weight:700;letter-spacing:0.1em;color:${phase.color};margin-bottom:3px;text-transform:uppercase;`}>{phase.label} — {phase.days}</div>
              <h3 style="font-size:1.1rem;font-weight:800;color:#f1f5f9;margin-bottom:2px;">{phase.theme}</h3>
              <p style="font-size:0.82rem;color:#64748b;">{phase.desc}</p>
            </div>
          </div>

          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:12px;">
            {phase.days_data.map((day, di) => (
              <div class={`reveal stagger-${di + 1}`}>
                <DayCard
                  day={day.data.day}
                  title={day.data.title}
                  level={day.data.level}
                  duration={day.data.duration}
                  id={day.id}
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

  </div>
</Layout>
