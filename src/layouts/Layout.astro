---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AIに仕事を奪われない人になる10日間研修' } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-192.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title} | AI研修プログラム</title>
  </head>
  <body style="background-color: var(--c-bg); color: #e2e8f0;" class="min-h-screen flex flex-col">

    <!-- ヘッダー：グラスモーフィズム固定 -->
    <header id="site-header" style="
      position: fixed; top: 0; left: 0; right: 0; z-index: 50;
      background: rgba(5, 11, 24, 0.7);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(59, 130, 246, 0.1);
      transition: background 0.3s ease, border-color 0.3s ease;
    ">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group" style="text-decoration:none;">
          <!-- SVGアイコン -->
          <div style="
            width: 36px; height: 36px;
            border-radius: 10px;
            background: linear-gradient(135deg, #1d4ed8, #7c3aed);
            border: 1px solid rgba(139,92,246,0.4);
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 0 18px rgba(99,102,241,0.35);
            transition: box-shadow 0.3s ease, transform 0.2s ease;
            flex-shrink: 0;
          "
          onmouseover="this.style.boxShadow='0 0 30px rgba(139,92,246,0.6)';this.style.transform='scale(1.06)'"
          onmouseout="this.style.boxShadow='0 0 18px rgba(99,102,241,0.35)';this.style.transform='scale(1)'"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="3" fill="white" opacity="0.9"/>
              <circle cx="4"  cy="12" r="2" fill="white" opacity="0.5"/>
              <circle cx="20" cy="12" r="2" fill="white" opacity="0.5"/>
              <circle cx="12" cy="4"  r="2" fill="white" opacity="0.5"/>
              <circle cx="12" cy="20" r="2" fill="white" opacity="0.5"/>
              <circle cx="6.3"  cy="6.3"  r="1.5" fill="white" opacity="0.35"/>
              <circle cx="17.7" cy="6.3"  r="1.5" fill="white" opacity="0.35"/>
              <circle cx="6.3"  cy="17.7" r="1.5" fill="white" opacity="0.35"/>
              <circle cx="17.7" cy="17.7" r="1.5" fill="white" opacity="0.35"/>
              <line x1="12" y1="9"  x2="12" y2="6"  stroke="white" stroke-width="1.2" opacity="0.6"/>
              <line x1="12" y1="15" x2="12" y2="18" stroke="white" stroke-width="1.2" opacity="0.6"/>
              <line x1="9"  y1="12" x2="6"  y2="12" stroke="white" stroke-width="1.2" opacity="0.6"/>
              <line x1="15" y1="12" x2="18" y2="12" stroke="white" stroke-width="1.2" opacity="0.6"/>
              <line x1="9.5"  y1="9.5"  x2="7.5"  y2="7.5"  stroke="white" stroke-width="1" opacity="0.3"/>
              <line x1="14.5" y1="9.5"  x2="16.5" y2="7.5"  stroke="white" stroke-width="1" opacity="0.3"/>
              <line x1="9.5"  y1="14.5" x2="7.5"  y2="16.5" stroke="white" stroke-width="1" opacity="0.3"/>
              <line x1="14.5" y1="14.5" x2="16.5" y2="16.5" stroke="white" stroke-width="1" opacity="0.3"/>
            </svg>
          </div>

          <!-- テキスト -->
          <div>
            <div style="
              font-weight: 800; font-size: 0.92rem; letter-spacing: -0.01em;
              background: linear-gradient(90deg, #e2e8f0, #a5b4fc);
              -webkit-background-clip: text; background-clip: text;
              -webkit-text-fill-color: transparent;
              line-height: 1.2;
            ">AI研修プログラム</div>
            <div style="font-size: 0.62rem; color: #94a3b8; letter-spacing: 0.04em; margin-top: 1px;">
              10 Days · ChatGPT Mastery
            </div>
          </div>
        </a>

        <nav class="hidden md:flex items-center gap-1">
          {[
            { href: '/', label: 'ホーム' },
            { href: '/curriculum', label: 'カリキュラム' },
            { href: '/gpts', label: 'GPTs活用' },
          ].map(({ href, label }) => (
            <a href={href} style="
              padding: 6px 14px;
              border-radius: 8px;
              font-size: 0.85rem;
              color: #94a3b8;
              transition: color 0.2s, background 0.2s;
              text-decoration: none;
            "
            onmouseover="this.style.color='#e2e8f0';this.style.background='rgba(59,130,246,0.1)'"
            onmouseout="this.style.color='#94a3b8';this.style.background='transparent'"
            >{label}</a>
          ))}
          <a href="/submit" style="
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            color: #fff;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            text-decoration: none;
            box-shadow: 0 0 15px rgba(59,130,246,0.3);
            transition: box-shadow 0.2s, transform 0.2s;
          "
          onmouseover="this.style.boxShadow='0 0 25px rgba(59,130,246,0.6)';this.style.transform='translateY(-1px)'"
          onmouseout="this.style.boxShadow='0 0 15px rgba(59,130,246,0.3)';this.style.transform='translateY(0)'"
          >📝 クリア報告</a>

          <a href="/api/logout" style="
            padding:7px 14px;border-radius:8px;font-size:0.82rem;
            color:#64748b;text-decoration:none;transition:all 0.2s;
          "
          onmouseover="this.style.color='#f87171';this.style.background='rgba(239,68,68,0.08)'"
          onmouseout="this.style.color='#64748b';this.style.background='transparent'"
          >ログアウト</a>
        </nav>

        <!-- モバイル -->
        <nav class="md:hidden flex gap-2">
          <a href="/curriculum" style="padding:5px 10px;border-radius:6px;font-size:0.75rem;color:#94a3b8;background:rgba(59,130,246,0.1);">カリキュラム</a>
          <a href="/gpts" style="padding:5px 10px;border-radius:6px;font-size:0.75rem;color:#94a3b8;background:rgba(59,130,246,0.1);">GPTs</a>
          <a href="/api/logout" style="padding:5px 10px;border-radius:6px;font-size:0.75rem;color:#94a3b8;background:rgba(239,68,68,0.08);">ログアウト</a>
        </nav>
      </div>
    </header>

    <!-- ヘッダー分のスペーサー -->
    <div style="height: 64px;"></div>

    <main class="flex-1">
      <slot />
    </main>

    <footer style="
      background: rgba(5, 11, 24, 0.9);
      border-top: 1px solid rgba(59,130,246,0.1);
      padding: 32px 16px;
      text-align: center;
      margin-top: 0;
    ">
      <div style="max-width: 960px; margin: 0 auto;">
        <div style="
          font-size: 0.85rem;
          background: linear-gradient(90deg, #60a5fa, #a78bfa);
          -webkit-background-clip: text; background-clip: text;
          -webkit-text-fill-color: transparent;
          font-weight: 700; margin-bottom: 6px; letter-spacing: 0.02em;
        ">AI研修プログラム</div>
        <p style="font-size: 0.72rem; color: #94a3b8;">10 Days ChatGPT Mastery &copy; {new Date().getFullYear()}</p>
      </div>
    </footer>

    <!-- スクロールアニメーション -->
    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.reveal, .reveal-scale, .reveal-left').forEach(el => {
        observer.observe(el);
      });

      // ヘッダースクロール効果
      const header = document.getElementById('site-header');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 20) {
          header.style.background = 'rgba(5, 11, 24, 0.92)';
          header.style.borderBottomColor = 'rgba(59, 130, 246, 0.2)';
        } else {
          header.style.background = 'rgba(5, 11, 24, 0.7)';
          header.style.borderBottomColor = 'rgba(59, 130, 246, 0.1)';
        }
      }, { passive: true });
    </script>
  </body>
</html>
