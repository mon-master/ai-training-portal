---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AIに仕事を奪われない人になる10日間研修' } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | AI研修プログラム</title>
  </head>
  <body class="bg-gray-50 text-gray-800 min-h-screen flex flex-col">
    <header class="bg-gradient-to-r from-blue-600 to-blue-800 text-white shadow-lg">
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 hover:opacity-90 transition-opacity">
          <span class="text-2xl">🤖</span>
          <div>
            <div class="font-bold text-lg leading-tight">AI研修プログラム</div>
            <div class="text-blue-200 text-xs">AIに仕事を奪われない人になる10日間</div>
          </div>
        </a>
        <nav class="hidden md:flex items-center gap-1">
          <a href="/" class="px-3 py-2 rounded-lg text-sm hover:bg-white/20 transition-colors">ホーム</a>
          <a href="/curriculum" class="px-3 py-2 rounded-lg text-sm hover:bg-white/20 transition-colors">カリキュラム</a>
          <a href="/gpts" class="px-3 py-2 rounded-lg text-sm hover:bg-white/20 transition-colors">GPTs活用</a>
          <a href="/submit" class="px-3 py-2 rounded-lg text-sm bg-white/20 hover:bg-white/30 transition-colors">ワークログ提出</a>
        </nav>
        <!-- モバイルメニュー（簡易版） -->
        <nav class="md:hidden flex gap-1">
          <a href="/curriculum" class="px-2 py-1 rounded text-xs bg-white/20">カリキュラム</a>
          <a href="/gpts" class="px-2 py-1 rounded text-xs bg-white/20">GPTs</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-gray-800 text-gray-400 text-sm py-6 mt-12">
      <div class="max-w-5xl mx-auto px-4 text-center">
        <p>AI研修プログラム &copy; {new Date().getFullYear()}</p>
        <p class="mt-1 text-xs text-gray-500">AIに仕事を奪われない人になる10日間研修</p>
      </div>
    </footer>
  </body>
</html>
