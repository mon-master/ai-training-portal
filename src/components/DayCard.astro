---
interface Props {
  day: number;
  title: string;
  level: string;
  duration: string;
  id: string;
  isCompleted?: boolean;
}

const { day, title, level, duration, id, isCompleted = false } = Astro.props;

function getPhase(day: number): { label: string; color: string; bg: string; glow: string } {
  if (day <= 3) return { label: '前半', color: '#3b82f6', bg: 'rgba(59,130,246,0.1)', glow: 'rgba(59,130,246,0.15)' };
  if (day <= 6) return { label: '中盤', color: '#8b5cf6', bg: 'rgba(139,92,246,0.1)', glow: 'rgba(139,92,246,0.15)' };
  return { label: '後半', color: '#06b6d4', bg: 'rgba(6,182,212,0.1)', glow: 'rgba(6,182,212,0.15)' };
}

const phase = getPhase(day);
const dayNum = String(day).padStart(2, '0');
---

<a href={`/days/${id.replace('.md', '')}`}
   class="glow-card"
   style={`
     display: block;
     border-radius: 16px;
     padding: 20px 22px;
     text-decoration: none;
     position: relative;
     overflow: hidden;
   `}
>
  <!-- 上部グロー -->
  <div style={`position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,${phase.color}60,transparent);`}></div>

  <div style="display: flex; align-items: center; gap: 16px;">
    <!-- Day番号バッジ -->
    <div style={`
      flex-shrink: 0;
      width: 52px; height: 52px;
      border-radius: 14px;
      background: linear-gradient(135deg, ${phase.color}20, ${phase.color}08);
      border: 1px solid ${phase.color}40;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      transition: box-shadow 0.3s;
    `}>
      <div style={`font-size: 0.55rem; font-weight: 700; color: ${phase.color}; letter-spacing: 0.08em; margin-bottom: 1px;`}>DAY</div>
      <div style={`font-size: 1.1rem; font-weight: 900; color: ${phase.color}; line-height: 1;`}>{dayNum}</div>
    </div>

    <!-- コンテンツ -->
    <div style="flex: 1; min-width: 0;">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 5px; flex-wrap: wrap;">
        <span style={`
          font-size: 0.68rem; font-weight: 700; letter-spacing: 0.06em;
          color: ${phase.color}; background: ${phase.bg};
          border: 1px solid ${phase.color}30;
          padding: 2px 8px; border-radius: 100px;
        `}>{phase.label}</span>
        <span style="font-size: 0.72rem; color: #94a3b8;">{level}</span>
      </div>
      <h3 style="font-size: 0.9rem; font-weight: 700; color: #e2e8f0; line-height: 1.45; margin-bottom: 5px; transition: color 0.2s;">
        {title}
      </h3>
      <p style="font-size: 0.75rem; color: #94a3b8;">⏱ {duration}</p>
    </div>

    <!-- 矢印 -->
    <div style="flex-shrink: 0; color: #64748b; transition: color 0.2s, transform 0.2s;">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</a>
